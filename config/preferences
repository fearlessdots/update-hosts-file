# Default editor (nano, vim, emacs, micro,...)
DEFAULT_EDITOR micro
# Default viewer (less, cat, batcat,...)
DEFAULT_VIEWER batcat
# Maximum number of files in backup directory
MAX_BACKUP_FILES 10
# Tell the program to skip module (and to not restore backup) if any web module source can not be reached
KEEP_ON_HOST_UNREACHABLE false
# Automatically verify if a newer version is available
AUTO_VERIFY_UPGRADE true
